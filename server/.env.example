# ─── Server ────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── PostgreSQL ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elitemotors
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Auth ──────────────────────────────────
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_this_too
